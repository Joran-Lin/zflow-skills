# Normalize line endings: LF in the repo, native on checkout.
# Fixes the "LF will be replaced by CRLF" warnings seen on Windows checkouts.
* text=auto eol=lf

# Windows-only scripts must keep CRLF.
*.bat   text eol=crlf
*.ps1   text eol=crlf
*.cmd   text eol=crlf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.mp4   binary
*.mp3   binary
*.wav   binary
*.m4a   binary
*.woff  binary
*.woff2 binary
