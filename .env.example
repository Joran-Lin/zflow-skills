# Zhipu AI API Key — 用于图片生成 + GLM-TTS（获取: https://open.bigmodel.cn）
ZHIPU_API_KEY=your_api_key_here

# MiniMax API Key — 可选，仅当 /tts 选择 minimax 引擎时需要（获取: https://platform.minimaxi.com/user-center/basic-information/interface-key）
MINIMAX_API_KEY=your_minimax_key_here

# Pexels API Key (get from https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_key_here

# Pixabay API Key (get from https://pixabay.com/api/docs/)
PIXABAY_API_KEY=your_pixabay_key_here
