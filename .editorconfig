root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Markdown: trailing two spaces can mean a hard line break; do not strip them.
trim_trailing_whitespace = false

[*.{bat,ps1,cmd}]
end_of_line = crlf
