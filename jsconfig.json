{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "paths": {
      "@scripts/*": ["./scripts/*"]
    }
  },
  "exclude": ["node_modules", "output", ".hyperframes"]
}

